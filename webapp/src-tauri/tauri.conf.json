{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-app",
  "version": "0.0.1-prealpha-5f67b68",
  "identifier": "com.example.project",
  "build": {
    "beforeDevCommand": "vite --config vite.config.app.ts",
    "devUrl": "http://localhost:10520",
    "beforeBuildCommand": "vite build --config vite.config.app.ts",
    "frontendDist": "../dist/src-tauri/src/frontend"
  },
  "app": {
    "windows": [
      {
        "title": "My App",
        "width": 1084,
        "height": 784
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/branding/icon.ico"
    ],
    "resources": []
  }
}