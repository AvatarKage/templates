{
  "name": "my-app",
  "version": "0.0.1-prealpha-811b96b",
  "license": "Copyright (c) 2026 Example, LLC. All Rights Reserved.",
  "type": "module",
  "scripts": {
    "start": "pm2 start ecosystem.config.cjs && pm2 monit",
    "dev": "pm2 start dev.ecosystem.config.cjs && pm2 monit",
    "stop": "pm2 stop all && pm2 kill",
    "sandbox": "tsx sandbox/%npm_config_name%.test.ts",
    "backup": "tsx dev/backup.ts",
    "update": "tsx dev/node/update.mts",
    "build": "tsx dev/node/build.mts",
    "clean": "rimraf dist && rimraf logs",
    "sync": "tsx dev/syncConfig.ts",
    "translate": "tsx dev/translateLocales.ts",
    "minify": "npx esbuild \"dist/**/*.js\" --format=esm --minify --banner:js=\"/* This file is part of My App. Copyright (c) 2026 Example, LLC. All Rights Reserved. */\" --outdir=dist --allow-overwrite",
    "delete:dist:dev": "rimraf dist/dev",
    "delete:dist:sandbox": "rimraf dist/sandbox",
    "delete:dist:src:types": "rimraf dist/src/types",
    "delete:dist:vite": "rimraf dist/vite.config.js",
    "copy:ssl": "cpx ssl/**/* dist/ssl",
    "copy:public": "cpx public/**/* dist/public",
    "copy:package": "cpx package.json dist",
    "copy:env": "cpx .env dist",
    "copy:ecosystem": "cpx ecosystem.config.cjs dist"
  },
  "dependencies": {
    "@sapphire/stopwatch": "^1.5.4",
    "@tailwindcss/vite": "^4.2.4",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.6.1",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.3.4",
    "http-proxy": "^1.18.1",
    "i18next": "^26.0.8",
    "i18next-http-backend": "^3.0.6",
    "luxon": "^3.7.2",
    "node-cron": "^4.2.1",
    "path": "^0.12.7",
    "pm2": "^6.0.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2",
    "robots-parser": "^3.0.1",
    "tailwindcss": "^4.2.4",
    "tldts": "^7.0.28",
    "translate": "^3.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/http-proxy": "^1.17.17",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/voucher-code-generator": "^1.1.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cli-progress": "^3.12.0",
    "cpx": "^1.5.0",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "execa": "^9.6.1",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
